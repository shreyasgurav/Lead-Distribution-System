// Prowider Mini Lead Distribution System — Prisma schema
// Database: PostgreSQL (Neon / Supabase / local)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Service {
  id    Int    @id @default(autoincrement())
  name  String @unique
  leads Lead[]
}

model Provider {
  id              Int               @id @default(autoincrement())
  name            String            @unique
  monthlyQuota    Int               @default(10)
  leadsReceived   Int               @default(0)
  assignments     LeadAssignment[]
}

model Lead {
  id          Int              @id @default(autoincrement())
  name        String
  phone       String
  city        String
  serviceId   Int
  description String
  createdAt   DateTime         @default(now())
  service     Service          @relation(fields: [serviceId], references: [id])
  assignments LeadAssignment[]

  // Enforce no duplicate phone+service at DB level (idempotency / dedupe)
  @@unique([phone, serviceId])
  @@index([createdAt])
}

model LeadAssignment {
  id         Int      @id @default(autoincrement())
  leadId     Int
  providerId Int
  assignedAt DateTime @default(now())
  lead       Lead     @relation(fields: [leadId], references: [id])
  provider   Provider @relation(fields: [providerId], references: [id])

  // Same provider cannot receive same lead twice
  @@unique([leadId, providerId])
  @@index([assignedAt])
  @@index([providerId])
}

// Round-robin state per service. Persisted so it survives restarts and
// scales across serverless instances.
model AllocationState {
  id        Int      @id @default(autoincrement())
  serviceId Int      @unique
  pool      Json     // ordered array of provider IDs eligible for this service
  pointer   Int      @default(0) // current round-robin index
  updatedAt DateTime @updatedAt
}

// Webhook idempotency table — stores processed idempotency keys.
model WebhookEvent {
  id          String   @id // client-provided idempotency key (UUID)
  type        String
  processedAt DateTime @default(now())
}
